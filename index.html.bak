<!DOCTYPE html>
<html lang="en" style="scroll-behavior: smooth;">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Heirloom Store - Spring & Mother's Day</title>
    
    <link rel="icon" href="logo.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Playfair+Display:wght@700&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --text-charcoal: #333333; 
            --accent-pink: #FF80AB; /* Softer Spring Pink */
            --accent-sage: #81C784; /* Spring Sage Green */
            --btn-shadow: #C2185B; 
            --header-brown: #5D4037; 
        }

        body {
            color: var(--text-charcoal);
            font-family: 'Inter', sans-serif;
            background-color: #fdfaf6; 
        }

        .fixed-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('mansion-background.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            z-index: -2;
        }

        .bg-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.3); /* Lighter overlay for Spring */
            z-index: -1;
        }

        h1, h2, h3, h4, h5, h6 { font-family: 'Playfair Display', serif; }
        .font-holiday { font-family: 'Great Vibes', cursive; }

        .glass-section {
            background: rgba(255, 255, 255, 0.92); 
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.1);
            border-radius: 2.5rem;
            margin: 4rem auto;
            padding: 4rem 2rem;
        }

        .btn-3d {
            background-color: var(--accent-pink);
            color: #ffffff;
            font-weight: 700;
            padding: 0.5rem 1rem; 
            border-radius: 9999px; 
            transition: all 0.2s ease;
            box-shadow: 0px 3px 0px var(--btn-shadow); 
            text-transform: uppercase;
            font-size: 0.7rem; 
            display: inline-block;
        }
        
        .btn-3d-sage {
            background-color: var(--accent-sage);
            box-shadow: 0px 3px 0px #388E3C;
        }

        .header-logo {
            width: 110px; height: 110px;
            object-fit: cover; border-radius: 50%;
            border: 3px solid white; background: white;
        }

        .falling-element {
            position: fixed; top: -50px; z-index: 9999;
            pointer-events: none; animation: fall linear infinite;
        }

        @keyframes fall { to { transform: translateY(110vh) rotate(360deg); } }

        .img-frame {
            border: 6px solid white; box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            background: white; overflow: hidden;
        }
    </style>
</head>
<body>

    <div class="fixed-bg"></div>
    <div class="bg-overlay"></div>

    <header class="bg-white/95 backdrop-blur-md shadow-sm sticky top-0 z-[100]">
        <div class="max-w-[1600px] mx-auto flex items-center justify-between px-6 py-3">
            <img src="logo.png" alt="Heirloom Logo" class="header-logo">

            <div class="flex flex-col items-center flex-1 mx-4 text-center">
                <h1 class="header-title text-4xl md:text-5xl lg:text-6xl font-bold text-pink-400">The Heirloom Store</h1>
                <nav class="hidden md:flex gap-3 mt-2">
                    <a href="#home" class="btn-3d">Home</a>
                    <a href="#cafe" class="btn-3d btn-3d-sage">The Express Cafe</a>
                    <a href="#spring-collection" class="btn-3d">Spring Arrivals</a>
                    <a href="#history" class="btn-3d">History</a>
                    <a href="#malina" class="btn-3d">Founder</a>
                </nav>
            </div>

            <img src="heirloom-express-logo.jpg" alt="Heirloom Express Logo" class="header-logo">
        </div>
    </header>

    <main class="max-w-[1400px] mx-auto px-4 relative z-10">
        
        <!-- Hero Section -->
        <section id="home" class="min-h-[60vh] flex flex-col items-center justify-center text-center pt-10">
            <div class="bg-white/60 backdrop-blur-md p-10 rounded-[3rem] border border-white/40 shadow-xl">
                <div class="inline-block bg-pink-400 text-white px-8 py-2 rounded-full font-bold mb-6 tracking-widest uppercase text-sm">
                    🌸 Celebrate Mother's Day with Us 🌸
                </div>
                <h2 class="font-holiday text-pink-500 text-6xl md:text-8xl mb-4">Spring Renewal</h2>
                <p class="text-gray-700 text-lg md:text-2xl font-light tracking-wide italic">
                    Fresh Blooms, Vintage Treasures, & Warm Espresso
                </p>
            </div>
        </section>

        <!-- NEW: The Heirloom Express Cafe Section -->
        <section id="cafe" class="glass-section border-l-8 border-sage-400">
            <div class="grid lg:grid-cols-2 gap-12 items-center">
                <div>
                    <h2 class="text-4xl font-bold text-emerald-800 mb-6 italic">The Heirloom Express Cafe</h2>
                    <h3 class="text-2xl text-pink-500 font-holiday mb-4">Mother's Day Tea & Coffee Specials</h3>
                    <p class="text-gray-700 leading-relaxed mb-6">
                        Step onto our restored 19th-century railcar for a Spring experience like no other. This season, we're featuring our <strong>"Lavender Honey Latte"</strong> and <strong>"Rose Petal Shortbread"</strong>—the perfect treats to share with Mom.
                    </p>
                    <ul class="space-y-3 text-gray-600 mb-8">
                        <li>🌿 <strong>Outdoor Seating:</strong> Enjoy the Georgia Spring air on our patio.</li>
                        <li>☕ <strong>Gift Bundles:</strong> Bagged roasts paired with vintage mugs.</li>
                        <li>🍰 <strong>Pastry Box:</strong> Pre-order a Mother's Day treat box.</li>
                    </ul>
                    <a href="#" class="btn-3d btn-3d-sage px-8 py-3">View Seasonal Menu</a>
                </div>
                <div class="img-frame rounded-3xl aspect-video">
                    <img src="https://images.unsplash.com/photo-1501339819358-ee5f8a17f2cd?auto=format&fit=crop&q=80&w=800" alt="Coffee and Flowers">
                </div>
            </div>
        </section>

        <!-- NEW: Spring Collection Creative Section -->
        <section id="spring-collection" class="glass-section bg-pink-50/50">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h2 class="text-4xl font-bold text-gray-800 mb-4">April Showers bring May Heirlooms</h2>
                <p class="text-gray-600 italic">Curated Spring decor and gifts for the mothers in your life.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="flex flex-col items-center">
                    <div class="aspect-square w-full rounded-2xl img-frame mb-4">
                        <img src="https://images.unsplash.com/photo-1490750967868-88aa4486c946?auto=format&fit=crop&q=80&w=400" alt="Flowers">
                    </div>
                    <h4 class="font-bold text-emerald-800 uppercase text-sm">Garden Vintage</h4>
                    <p class="text-xs text-gray-500">Apothecary jars & planters</p>
                </div>
                <div class="flex flex-col items-center">
                    <div class="aspect-square w-full rounded-2xl img-frame mb-4">
                        <img src="https://images.unsplash.com/photo-1526047932273-341f2a7631f9?auto=format&fit=crop&q=80&w=400" alt="Mother's Day Gift">
                    </div>
                    <h4 class="font-bold text-emerald-800 uppercase text-sm">Handcrafted Jewelry</h4>
                    <p class="text-xs text-gray-500">Local artisan Mother's Day picks</p>
                </div>
                <div class="flex flex-col items-center">
                    <div class="aspect-square w-full rounded-2xl img-frame mb-4">
                        <img src="https://images.unsplash.com/photo-1516733725897-1aa73b87c8e8?auto=format&fit=crop&q=80&w=400" alt="Spring Textiles">
                    </div>
                    <h4 class="font-bold text-emerald-800 uppercase text-sm">Linen & Lace</h4>
                    <p class="text-xs text-gray-500">Table runners & Spring textiles</p>
                </div>
            </div>
        </section>

        <!-- MANDEVILLE MANSION LEGACY (Unchanged as requested) -->
        <section id="history" class="glass-section">
            <h2 class="text-5xl font-bold text-emerald-900 mb-16 text-center">Mandeville Mansion Legacy</h2>
            <div class="grid lg:grid-cols-2 gap-16">
                <div class="space-y-12">
                    <div>
                        <span class="text-pink-500 font-bold text-sm tracking-tighter uppercase">1889—1894</span>
                        <h4 class="text-2xl font-bold mb-4 text-emerald-800">Technological Pioneers</h4>
                        <p class="text-gray-700 leading-relaxed">
                            Built by <strong>L.C. Mandeville</strong>, this home was an engineering marvel. It boasted Carrollton's first 
                            indoor plumbing and telephone line. To ensure water pressure, massive storage tanks were hidden within the third-floor walls.
                        </p>
                    </div>
                    <div class="relative group">
                        <div class="aspect-[16/9] img-frame rounded-2xl">
                            <img src="original-mansion.jpg" alt="Original Mansion View" onerror="this.src='https://placehold.co/800x450?text=Original+Mansion'">
                        </div>
                        <div class="mt-4">
                            <h4 class="text-2xl font-bold mb-2 text-emerald-800">The "Maple Street" Origin</h4>
                            <p class="text-gray-700">
                                Mandeville imported <strong>Vermont Maple trees</strong> to Carrollton to help his wife, Mary Ann, feel more 
                                at home. This act of love eventually led to the renaming of Bowdon Street to Maple Street.
                            </p>
                        </div>
                    </div>
                    <div class="bg-white/60 p-6 rounded-2xl border-l-4 border-emerald-600 shadow-sm">
                        <h4 class="text-2xl font-bold mb-2 text-emerald-800">The Railroad Car</h4>
                        <p class="text-gray-700 leading-relaxed">
                            In the 1960s, a 19th-century railcar was added to the mansion's side. It has served as everything from a ballroom to a restaurant, now reborn as our specialty coffee house.
                        </p>
                    </div>
                </div>
                <div class="space-y-8">
                    <div class="grid grid-cols-2 gap-6">
                        <div class="flex flex-col"><div class="aspect-square rounded-2xl img-frame mb-2"><img src="mansion-1950.jpg"></div><span class="text-xs font-bold text-center uppercase text-gray-500">Historic Photo</span></div>
                        <div class="flex flex-col"><div class="aspect-square rounded-2xl img-frame mb-2"><img src="mansion-1960.png"></div><span class="text-xs font-bold text-center uppercase text-gray-500">Historic Photo</span></div>
                        <div class="flex flex-col"><div class="aspect-square rounded-2xl img-frame mb-2"><img src="original-mansion-owner.jpg"></div><span class="text-xs font-bold text-center uppercase text-gray-500">Original Owner</span></div>
                        <div class="flex flex-col"><div class="aspect-square rounded-2xl img-frame mb-2"><img src="mansion-window.jpg"></div><span class="text-xs font-bold text-center uppercase text-gray-500">The 3rd Floor Window</span></div>
                    </div>
                    <div class="bg-emerald-900 text-white p-10 rounded-[2.5rem] shadow-2xl relative overflow-hidden">
                        <h3 class="text-3xl font-bold mb-4 font-holiday italic text-emerald-100">Legends & Spirits</h3>
                        <p class="text-emerald-50 text-base leading-relaxed italic relative z-10">
                            "The Mansion is not without its mysteries. Local legend speaks of Eugenia Mandeville, whose presence 
                            is said to still linger. Passersby often report seeing silhouettes watching from the 
                            third-story window long after the store has closed."
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- A JOURNEY OF RENEWED PURPOSE (Unchanged as requested) -->
        <section id="malina" class="glass-section mb-32">
            <div class="grid lg:grid-cols-2 gap-20 items-center">
                <div class="order-2 lg:order-1 flex flex-col items-center">
                    <div class="relative w-full max-w-md group">
                        <div class="aspect-[4/5] rounded-[2.5rem] img-frame relative z-20"><img src="malina-owner.jpg"></div>
                        <div class="absolute -inset-6 bg-gradient-to-tr from-pink-400/20 to-emerald-400/20 blur-3xl rounded-3xl z-10"></div>
                        <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 bg-emerald-900 text-white px-12 py-4 rounded-full font-holiday text-4xl whitespace-nowrap z-30 shadow-2xl">Malina Falkner</div>
                    </div>
                    <div class="grid grid-cols-4 gap-4 mt-20 w-full">
                        <div class="aspect-square rounded-2xl img-frame"><img src="malina-family.jpg"></div>
                        <div class="aspect-square rounded-2xl img-frame"><img src="malina-jacob-son.jpg"></div>
                        <div class="aspect-square rounded-2xl img-frame"><img src="malina-mom-1.jpg"></div>
                        <div class="aspect-square rounded-2xl img-frame"><img src="malina-mom-sister.jpg"></div>
                    </div>
                    <p class="mt-4 text-xs font-bold text-gray-400 uppercase tracking-widest">In Memory of Darlene & Jacob</p>
                </div>
                <div class="order-1 lg:order-2">
                    <h2 class="text-5xl font-bold text-emerald-900 mb-8">A Journey of Renewed Purpose</h2>
                    <div class="space-y-6 text-gray-700 text-lg leading-relaxed">
                        <p>For Malina Falkner, opening The Heirloom Store was a calling born from loss. Following the passing of her mother, <strong>Darlene</strong>, and the unexpected loss of her son, <strong>Jacob</strong>, Malina sought to navigate her grief through service and creation.</p>
                        <p>She found a path to renewed purpose by giving back, helping those who have experienced their own storms find a sense of beauty and continuity.</p>
                        <blockquote class="border-l-8 border-pink-400 bg-pink-50 p-8 rounded-r-3xl italic font-serif text-emerald-900 text-xl shadow-inner">
                            "The store is my way of breathing new life into the old. By locally crafting and repurposing items, we insert joy back into the community, showing that growth is always possible."
                        </blockquote>
                        <p>Every antique treasure and handcrafted heirloom in the store tells a story of endurance. Malina’s vision was to revitalize history—offering a sanctuary where memories are honored and new beginnings are celebrated every day.</p>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <footer class="bg-emerald-950 text-white pt-24 pb-12 relative z-10">
        <div class="max-w-6xl mx-auto px-6 text-center">
            <img src="logo.png" alt="Footer Logo" class="w-32 h-32 mx-auto rounded-full mb-8 border-4 border-white/10 shadow-2xl object-cover bg-white">
            <h3 class="font-holiday text-6xl mb-8 text-emerald-100">The Heirloom Store</h3>
            <p class="text-emerald-100/20 text-xs italic tracking-widest uppercase">&copy; 2026 The Heirloom Store LLC. Honoring history, crafting hope.</p>
        </div>
    </footer>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const container = document.body;
            const symbols = ['🌸', '☕', '🌷', '🦋', '🍃']; // Updated symbols for Spring
            function createFallingElement() {
                const el = document.createElement('div');
                el.classList.add('falling-element');
                el.innerText = symbols[Math.floor(Math.random() * symbols.length)];
                el.style.left = Math.random() * 98 + 'vw';
                el.style.opacity = Math.random() * 0.4 + 0.2; 
                el.style.fontSize = (Math.random() * 20 + 15) + 'px'; 
                const duration = Math.random() * 10 + 15; 
                el.style.animationDuration = duration + 's';
                container.appendChild(el);
                setTimeout(() => el.remove(), duration * 1000);
            }
            setInterval(createFallingElement, 2500); 
        });
    </script>
</body>
</html>